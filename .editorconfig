# C:\xampp\htdocs\HontoriaPrintingServices\.editorconfig

# Top-most EditorConfig file
root = true

# ── Global Defaults ──
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ── PHP Files ──
# Braces on SAME line (K&R / 1TBS style)
# public function example() {
#     // code
# }
[*.php]
indent_style = space
indent_size = 4
curly_bracket_next_line = false

# ── HTML / Views ──
# Indent children of <html> including <head> and <body>
# <html>
#     <head>
#         <title>...</title>
#     </head>
#     <body>
#         <h1>...</h1>
#     </body>
# </html>
[*.{html,php}]
indent_style = space
indent_size = 4

# ── CSS ──
[*.css]
indent_style = space
indent_size = 4

# ── JavaScript ──
[*.js]
indent_style = space
indent_size = 4

# ── SQL Migrations ──
[*.sql]
indent_style = space
indent_size = 4

# ── Markdown ──
[*.md]
trim_trailing_whitespace = false

# ── JSON / Config ──
[*.{json,yml,yaml}]
indent_style = space
indent_size = 2
